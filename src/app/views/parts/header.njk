<header>
    <div class="container">
        <a href="/">
            <div class="logo">
                <h1>Launchstore</h1>
                <h2>Compra e Venda</h2>
            </div>
        </a>
    

        <form action="/products/search" method="GET" class="search">
            <input type="text"
                name="filter"
                placeholder="Buscar por Produtos"
                {% if search.term %}
                        value="{{search.term}}"
                {% endif %}
                >
        </form>

        <nav class="primary">
            <ul>
                <li>
                    <a href="/ads/create">
                        <i class="material-icons">add</i> 
                        Novo anúncio
                    </a>
                </li>
                <li>
                    <a href="/acounts">
                        <i class="material-icons">account_circle</i>
                        Minha conta
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>