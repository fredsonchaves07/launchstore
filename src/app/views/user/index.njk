{% extends 'layout.njk' %}
{% block content %}
<section class="user-dashboad container form">
    <form action="/users?_method=PUT" method="POST">
        <div class="header">
            <h3>Detalhes</h3>
        </div>

        <div class="fields">
            {% include 'user/fields.njk' %}
            <input type="hidden" name="id" value="{{user.id}}">
        </div>
        <button class="button edit" type="submit">Salvar</button>
    </form>

    <form action="/users?_method=DELETE" method="POST" id="delete" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{user.id}}">
        <button class="button delete" type="submit" >Deletar</button>
    </form>
</section>

<script>
    const formDelete = document.getElementById('delete')
        formDelete.addEventListener('submit', function(event){
        const confirmation = confirm('Tem certeza que deseja excluir a sua conta. A operação não poderá ser desfeita?')
        if(!confirmation){
            event.preventDefault()
        }
    })
</script>    

{% endblock content %}
